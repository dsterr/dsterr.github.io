---
layout: none
---

[
{% assign items = site.pages | concat: site.activity %}
{% for item in items %}
  {% if item.title and item.search_exclude != true %}
    {
      "title": {{ item.title | jsonify }},
      "url": "{{ item.url }}",
      "content": {{ item.content | strip_html | jsonify }}
    }{% unless forloop.last %},{% endunless %}
  {% endif %}
{% endfor %}
]
